# Copy this file to `.env` and fill in the options you need.
# Layer 1 (regex) and Layer 2 (embeddings) work without any of this.
# Layer 3 (LLM verdict + reset/summary helpers) needs one LLM backend.

# ============================================================
# Optional FinOps API token
# ============================================================
# If FINOPS_API_TOKEN is set on the server, /metrics and /aggregate require it.
# Set the same value for every reporter that uploads to that server.
#
# FINOPS_API_TOKEN=change-this-token
#
# Optional reporter defaults:
# FINOPS_SERVER_URL=http://127.0.0.1:8787
# FINOPS_TEAM=engineering

# ============================================================
# Option A: OpenRouter (cloud)
# ============================================================
# Get a key here:
#   https://openrouter.ai/keys
#
# OPENROUTER_API_KEY=sk-or-v1-paste-your-key-here
#
# Optional model override:
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# ============================================================
# Option B: Ollama (fully local)
# ============================================================
# Requires Ollama running on http://localhost:11434 with at least one
# instruct-style model pulled. Example:
#   ollama pull llama3.1:8b
#
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_URL=http://localhost:11434

# Leave everything commented to use only Layer 1 + Layer 2.
